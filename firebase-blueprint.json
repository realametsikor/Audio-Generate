{
  "entities": {
    "RadioShow": {
      "title": "RadioShow",
      "description": "A generated radio show",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "duration": { "type": "number" },
        "summary": { "type": "string" },
        "date": { "type": "string" },
        "host": { "type": "string" },
        "coverImage": { "type": "string" },
        "audioUrl": { "type": "string" },
        "notesUrl": { "type": "string" },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" },
              "speaker": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["title", "duration", "summary", "date", "host", "coverImage", "audioUrl", "transcript", "userId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}/shows/{showId}": {
      "schema": { "$ref": "#/entities/RadioShow" },
      "description": "Radio shows generated by a user"
    }
  }
}
